class Solution {
    public int findDuplicate(int[] nums) {
        
        boolean[] arr = new boolean[nums.length];
        for(int i=0;i<=nums.length;i++) {
            int idx = nums[i];
            if(arr[idx] == true) return idx;
            else arr[idx] = true; 
        }
